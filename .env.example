# Copy to .env and adjust as needed: cp .env.example .env

# Absolute host path to your real music library.
MUSIC_LIBRARY_PATH=/absolute/path/to/your/music

# Host port to expose the web UI/API on.
PORT=8080

# Required for identification. Register a free application at
# https://acoustid.org/new-application to get an API key.
ACOUSTID_API_KEY=

# Required for identification. MusicBrainz requires a descriptive
# User-Agent identifying your application (name/version/contact) — generic
# or missing User-Agents may be rate-limited or blocked.
MUSICBRAINZ_USER_AGENT=music-tagger/0.1 ( your-email@example.com )
